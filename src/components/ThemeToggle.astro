---
// 3-way theme toggle: Dark | System | Light
// State is managed via localStorage; html class is applied by Layout.astro blocking script
---

<div class="theme-track" role="group" aria-label="Theme preference">
  <div class="theme-indicator" id="theme-indicator" aria-hidden="true"></div>

  <button class="theme-btn" data-theme="dark" aria-label="Dark theme" aria-pressed="false" title="Dark theme">
    <!-- Moon -->
    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>

  <button class="theme-btn" data-theme="system" aria-label="System theme" aria-pressed="true" title="System theme">
    <!-- Monitor -->
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="3" width="20" height="14" rx="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </svg>
  </button>

  <button class="theme-btn" data-theme="light" aria-label="Light theme" aria-pressed="false" title="Light theme">
    <!-- Sun -->
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
</div>

<style>
  .theme-track {
    position: relative;
    display: flex;
    align-items: center;
    padding: 2px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-green);
    border-radius: 999px;
    flex-shrink: 0;
  }

  .theme-indicator {
    position: absolute;
    left: 2px;
    top: 2px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--green-primary);
    box-shadow: 0 0 8px var(--green-glow-strong);
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.35s ease,
      box-shadow 0.35s ease;
    z-index: 1;
    pointer-events: none;
  }

  .theme-btn {
    position: relative;
    z-index: 2;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .theme-btn.active {
    color: var(--toggle-active-icon);
  }

  .theme-btn:not(.active):hover {
    color: var(--green-primary);
  }
</style>

<script>
  const THEME_KEY = 'theme';
  const BTN_WIDTH = 28; // px — matches .theme-btn width

  const indicator = document.getElementById('theme-indicator') as HTMLElement | null;
  const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-btn');

  const POSITIONS: Record<string, number> = { dark: 0, system: 1, light: 2 };

  function isDark(): boolean {
    const h = document.documentElement;
    if (h.classList.contains('dark')) return true;
    if (h.classList.contains('light')) return false;
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  function updateUI(theme: string) {
    const pos = POSITIONS[theme] ?? 1;
    if (indicator) {
      indicator.style.transform = `translateX(${pos * BTN_WIDTH}px)`;
    }
    buttons.forEach((btn) => {
      const active = btn.dataset.theme === theme;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-pressed', String(active));
    });
  }

  function applyTheme(theme: string) {
    const html = document.documentElement;
    html.classList.add('theme-transitioning');
    html.classList.remove('dark', 'light');
    if (theme === 'dark')  html.classList.add('dark');
    if (theme === 'light') html.classList.add('light');
    localStorage.setItem(THEME_KEY, theme);
    updateUI(theme);
    document.dispatchEvent(
      new CustomEvent('themechange', { detail: { theme, isDark: isDark() } })
    );
    setTimeout(() => html.classList.remove('theme-transitioning'), 400);
  }

  // ─── Initial render (html class already applied by blocking script) ──
  const stored = localStorage.getItem(THEME_KEY) ?? 'system';
  updateUI(stored);

  // ─── Button clicks ──────────────────────────────────────────────────
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyTheme(btn.dataset.theme ?? 'system');
    });
  });

  // ─── System preference changes ──────────────────────────────────────
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if ((localStorage.getItem(THEME_KEY) ?? 'system') === 'system') {
      document.dispatchEvent(
        new CustomEvent('themechange', { detail: { theme: 'system', isDark: isDark() } })
      );
    }
  });
</script>
